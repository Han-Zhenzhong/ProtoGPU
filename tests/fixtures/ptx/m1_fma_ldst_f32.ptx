.version 6.4
.target sm_70
.address_size 64

.visible .entry m1_fma_ldst_f32(
    .param .u64 in_a,
    .param .u64 in_b,
    .param .u64 out,
    .param .u32 n
)
{
    .reg .u32 %r<4>;
    .reg .u64 %rd<8>;
    .reg .f32 %f<4>;
    .reg .pred %p<2>;

    ld.param.u64 %rd1, [in_a];
    ld.param.u64 %rd2, [in_b];
    ld.param.u64 %rd3, [out];
    ld.param.u32 %r1, [n];

    mov.u32 %r0, %tid.x;
    setp.lt.s32 %p0, %r0, %r1;

    // byte_offset = tid.x * 4
    mul.u32 %rd4, %r0, 4;

    add.u64 %rd5, %rd1, %rd4;
    ld.global.f32 %f0, [%rd5];

    add.u64 %rd5, %rd2, %rd4;
    ld.global.f32 %f1, [%rd5];

    // out = a*b + 1.0
    fma.f32 %f2, %f0, %f1, 0f3f800000;

    add.u64 %rd5, %rd3, %rd4;
    @%p0 st.global.f32 [%rd5], %f2;

    ret;
}
